Parameters from \code{\link{LearnerTorch}}, as well as:
\itemize{
\item \code{arch_type} :: \code{character(1)}\cr
The architecture type, one of:
\itemize{
\item \code{"tabm"} (default) -- BatchEnsemble with the TabM initialization, i.e. all
multiplicative adapters except the very first one are initialized with ones.
\item \code{"tabm-mini"} -- all non-shared parameters are concentrated in a single
elementwise affine transformation applied to the input.
\item \code{"tabm-packed"} -- \code{k} fully independent (packed) MLPs.
\item \code{"plain"} -- a plain MLP without any ensembling (\code{k} is ignored).
}
\item \code{k} :: \code{integer(1)}\cr
The number of ensemble members. Default is \code{32}.
\item \code{n_blocks} :: \code{integer(1)}\cr
The number of blocks of the MLP backbone. Default is \code{3}.
\item \code{d_block} :: \code{integer(1)}\cr
The width of the MLP backbone. Default is \code{512}.
\item \code{dropout} :: \code{numeric(1)}\cr
The dropout rate. Default is \code{0.1}.
\item \code{activation} :: \code{character(1)}\cr
The activation function. Default is \code{"relu"}.
\item \code{start_scaling_init} :: \code{character(1)}\cr
The initialization of the very first (non-shared) scaling, either \code{"random-signs"}
(default) or \code{"normal"}. Ignored for \code{arch_type} \code{"tabm-packed"} and \code{"plain"}.
}
}

\section{Loss and Prediction}{

The network output has shape \verb{(batch, k, d_out)}.
The learner therefore wraps the configured loss function (the default, or one passed
via the \code{loss} construction argument) such that the ensemble dimension is folded into
the batch dimension and each target is repeated \code{k} times.
For prediction, the per-submodel probabilities (softmax for multiclass, sigmoid for
binary) are averaged over the \code{k} submodels; for regression the outputs are averaged.
}

\examples{
\dontshow{if (torch::torch_is_installed()) withAutoprint(\{ # examplesIf}
# Define the Learner and set parameter values
learner = lrn("classif.tabm")
learner$param_set$set_values(
  epochs = 1, batch_size = 16, device = "cpu",
  k = 4, n_blocks = 2, d_block = 32
)

# Define a Task
task = tsk("iris")

# Create train and test set
ids = partition(task)

# Train the learner on the training ids
learner$train(task, row_ids = ids$train)

# Make predictions for the test rows
predictions = learner$predict(task, row_ids = ids$test)

# Score the predictions
predictions$score()
\dontshow{\}) # examplesIf}
}
